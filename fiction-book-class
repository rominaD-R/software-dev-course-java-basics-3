package org.example;

public class FictionBook extends Book {

    private String genre;

    public FicitonBook(String title, String author, int id, String genre) {
        super(title, author, id);
        this.genre = genre;
    }
    
    public static void toString() {
        return "Book " + id + ":  " + title + " by " + author + " about " + genre;
    }

    public static String getGenre() {
        return this.genre;
    }

    public static void setGenre(genre) {
       this.genre = genre;
    }

}
